rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /artifacts/{appId}/public/data/reservas_ccbs/{reservaId} {
      // Allow read for everyone
      allow read: if true;
      
      // Allow create if user is authenticated and provides required fields
      allow create: if request.auth != null 
        && request.resource.data.keys().hasAll(['auditorio', 'data', 'horaInicio', 'horaFim', 'nomeEvento', 'requisitante', 'cpf', 'email', 'telefone', 'senha'])
        && request.resource.data.auditorio is string
        && request.resource.data.data is string
        && request.resource.data.horaInicio is string
        && request.resource.data.horaFim is string
        && request.resource.data.nomeEvento is string
        && request.resource.data.requisitante is string;
        
      // Allow delete if authenticated
      // For this app, the delete action is protected on the client side via the "senha" check or "MASTER_PASSWORD"
      allow delete: if request.auth != null;
    }
  }
}
